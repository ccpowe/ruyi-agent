# Copy this file to `.env` and fill only the sections you use.
# Never commit `.env`; it may contain API keys, bot tokens, and gateway secrets.

# APP_MODE: Default entrypoint when running `python main.py` without an argument.
# Supported values: gateway, telegram, feishu, tui, interactive.
APP_MODE="gateway"

# AGENT_NODE_ID: Stable node identifier used by gateway/subagent delegation to
# detect loops across local and remote nodes. Required for all runtime modes.
AGENT_NODE_ID="local-dev"


## Model providers

# OPENROUTER_API_KEY: API key for providers.openrouter in config/llm_providers.toml.
# Required when any agent uses provider = "openrouter".
OPENROUTER_API_KEY=

# KIMI_API_KEY: API key for providers.kimi in config/llm_providers.toml and Kimi
# development probes.
KIMI_API_KEY=

# KIMI_OPENAI_BASE_URL: OpenAI-compatible Kimi endpoint used by
# scripts/tool_search_poc.py. Not required for normal runtime unless you use
# that script.
KIMI_OPENAI_BASE_URL=


## Backend runtime

# BACKEND_KIND: Tool execution backend. Use "local" for development on this
# machine, or "daytona" for a Daytona sandbox.
BACKEND_KIND="local"

# LOCAL_BACKEND_ROOT: Root directory exposed to the local backend when
# BACKEND_KIND="local". Empty means the current working directory.
LOCAL_BACKEND_ROOT=

# LOCAL_BACKEND_TIMEOUT: Maximum seconds for a local backend shell command.
LOCAL_BACKEND_TIMEOUT="120"

# LOCAL_BACKEND_MAX_OUTPUT_BYTES: Maximum captured stdout/stderr bytes for a
# local backend command before truncation.
LOCAL_BACKEND_MAX_OUTPUT_BYTES="100000"

# LOCAL_BACKEND_INHERIT_ENV: Whether local backend commands inherit the parent
# process environment.
LOCAL_BACKEND_INHERIT_ENV="true"

# LOCAL_BACKEND_SKILLS_ROOT: Optional skills directory exposed to agents in the
# local backend virtual filesystem. If set to an absolute path, it must be
# inside LOCAL_BACKEND_ROOT.
LOCAL_BACKEND_SKILLS_ROOT=

# DAYTONA_API_KEY: Daytona API key. Required only when BACKEND_KIND="daytona".
DAYTONA_API_KEY=

# DAYTONA_API_URL: Daytona API base URL. Optional unless your Daytona deployment
# requires a custom endpoint.
DAYTONA_API_URL=

# DAYTONA_TARGET: Daytona target selector. Optional; leave empty for Daytona's
# default target.
DAYTONA_TARGET=

# DAYTONA_SANDBOX_NAME: Stable sandbox name to reuse between runtime starts.
DAYTONA_SANDBOX_NAME=


## Gateway and runtime state

# GATEWAY_HOST: Host/interface uvicorn binds to in gateway mode.
GATEWAY_HOST="127.0.0.1"

# GATEWAY_PORT: Port uvicorn listens on in gateway mode.
GATEWAY_PORT="8000"

# GATEWAY_BEARER_TOKEN: Bearer token required by Gateway, Telegram, Feishu, and
# remote A2A clients. Use a long random value outside local experiments.
GATEWAY_BEARER_TOKEN="change-me-long-random-token"

# GATEWAY_BASE_URL: Gateway URL used by channel adapters such as Telegram and
# Feishu when they call the HTTP control plane.
GATEWAY_BASE_URL="http://127.0.0.1:8000"

# CHECKPOINT_DB: SQLite path for LangGraph checkpoints and resumable agent state.
CHECKPOINT_DB="data/checkpoints.sqlite"

# GATEWAY_ROUTE_DB: SQLite path for Gateway route records for local/remote tasks.
GATEWAY_ROUTE_DB="data/gateway_routes.sqlite"

# TASK_DB: SQLite path for async task records and terminal results.
TASK_DB="data/tasks.sqlite"

# REVIEW_AUDIT_DB: SQLite path for HITL approval/rejection audit records.
REVIEW_AUDIT_DB="data/review_audit.sqlite"

# CHANNEL_SESSION_DB: Shared fallback SQLite path for channel session stores when
# TELEGRAM_SESSION_DB or FEISHU_SESSION_DB are not set.
CHANNEL_SESSION_DB="data/channel_sessions.sqlite3"

# AGENT_MAX_DELEGATION_DEPTH: Maximum nested subagent delegation depth per root
# task. Must be a positive integer.
AGENT_MAX_DELEGATION_DEPTH="3"

# AGENT_MAX_TASKS_PER_ROOT: Maximum subagent tasks allowed under one root task.
# Must be a positive integer.
AGENT_MAX_TASKS_PER_ROOT="20"

# A2A_WEBHOOK_URL: Optional webhook URL for child task terminal notifications.
A2A_WEBHOOK_URL=

# A2A_WEBHOOK_TOKEN: Optional bearer token sent to A2A_WEBHOOK_URL. Empty falls
# back to GATEWAY_BEARER_TOKEN.
A2A_WEBHOOK_TOKEN=

# REMOTE_RESEARCH_TOKEN: Bearer token used by the commented remote_ref example
# in config/agents.toml.repo-default. Rename together with token_env if you
# change the agent config.
REMOTE_RESEARCH_TOKEN=


## LangSmith tracing

# LANGSMITH_TRACING: Enables LangSmith tracing when set to true.
LANGSMITH_TRACING="false"

# LANGSMITH_ENDPOINT: LangSmith API endpoint.
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

# LANGSMITH_API_KEY: LangSmith API key. Required only when tracing is enabled.
LANGSMITH_API_KEY=

# LANGSMITH_PROJECT: LangSmith project name for traces.
LANGSMITH_PROJECT=


## Telegram adapter

# TELEGRAM_BOT_TOKEN: Telegram bot token from BotFather. Required for telegram mode.
TELEGRAM_BOT_TOKEN=

# TELEGRAM_DEFAULT_AGENT: Public agent name used when Telegram messages do not
# explicitly select an agent.
TELEGRAM_DEFAULT_AGENT="main"

# TELEGRAM_SESSION_DB: SQLite path for Telegram chat/thread to agent session mapping.
TELEGRAM_SESSION_DB="data/channel_sessions.sqlite3"

# TELEGRAM_UPDATE_DB: SQLite path for processed Telegram update offsets/dedup state.
TELEGRAM_UPDATE_DB="data/telegram_updates.sqlite3"

# TELEGRAM_POLL_TIMEOUT: Long-poll timeout in seconds for getUpdates.
TELEGRAM_POLL_TIMEOUT="30"

# TELEGRAM_API_TIMEOUT: HTTP timeout in seconds for Telegram Bot API calls.
TELEGRAM_API_TIMEOUT="40"

# TELEGRAM_TASK_POLL_INTERVAL: Seconds between Gateway task status polls.
TELEGRAM_TASK_POLL_INTERVAL="2"

# TELEGRAM_TERMINAL_REVIEW_GRACE_CHECKS: Extra polls before sending terminal
# status when a task may still expose a pending review.
TELEGRAM_TERMINAL_REVIEW_GRACE_CHECKS="3"

# TELEGRAM_MESSAGE_PARSE_MODE: Telegram parse mode for outgoing messages.
# Common values: MarkdownV2, HTML, or empty for plain text.
TELEGRAM_MESSAGE_PARSE_MODE="MarkdownV2"

# TELEGRAM_MEDIA_MAX_BYTES: Maximum file size in bytes that Telegram adapter
# will read/send from generated artifacts.
TELEGRAM_MEDIA_MAX_BYTES="52428800"

# TELEGRAM_FALLBACK_IPS: Optional comma-separated Telegram API IP fallbacks for
# environments with DNS/connectivity issues.
TELEGRAM_FALLBACK_IPS=

# KROKI_BASE_URL: Kroki endpoint used to render Mermaid diagrams for Telegram.
KROKI_BASE_URL="https://kroki.io"


## Feishu / Lark adapter

# FEISHU_APP_ID: Feishu/Lark app ID. Required for feishu mode.
FEISHU_APP_ID=

# FEISHU_APP_SECRET: Feishu/Lark app secret. Required for feishu mode.
FEISHU_APP_SECRET=

# FEISHU_DOMAIN: SDK domain, usually "feishu" for Feishu or "larksuite" for Lark.
FEISHU_DOMAIN="feishu"

# FEISHU_CONNECTION_MODE: Feishu connection mode. Currently only "websocket" is
# supported by the adapter.
FEISHU_CONNECTION_MODE="websocket"

# FEISHU_DEFAULT_AGENT: Public agent name used for incoming Feishu messages.
FEISHU_DEFAULT_AGENT="main"

# FEISHU_SESSION_DB: SQLite path for Feishu chat/thread to agent session mapping.
FEISHU_SESSION_DB="data/channel_sessions.sqlite3"

# FEISHU_EVENT_DB: SQLite path for processed Feishu event dedup state.
FEISHU_EVENT_DB="data/feishu_events.sqlite3"

# FEISHU_REQUIRE_MENTION: In group chats, require an @mention before handling a
# message. Set false only for tightly controlled groups.
FEISHU_REQUIRE_MENTION="true"

# FEISHU_GROUP_POLICY: Group-chat policy. Use "disabled" for DM-only, "open" to
# allow groups, or pair with FEISHU_ALLOWED_GROUPS for tighter access.
FEISHU_GROUP_POLICY="disabled"

# FEISHU_ALLOWED_USERS: Optional comma-separated user IDs allowed to use the bot.
# Empty means no user allowlist.
FEISHU_ALLOWED_USERS=

# FEISHU_ALLOWED_GROUPS: Optional comma-separated group/chat IDs allowed to use
# the bot. Empty means no group allowlist.
FEISHU_ALLOWED_GROUPS=

# FEISHU_BOT_NAME: Bot display name used for group @mention detection when bot
# IDs are not configured.
FEISHU_BOT_NAME=

# FEISHU_BOT_OPEN_ID: Bot open_id used for group @mention detection.
FEISHU_BOT_OPEN_ID=

# FEISHU_BOT_USER_ID: Bot user_id used for group @mention detection.
FEISHU_BOT_USER_ID=

# FEISHU_BOT_UNION_ID: Bot union_id used for group @mention detection.
FEISHU_BOT_UNION_ID=

# FEISHU_API_TIMEOUT: HTTP timeout in seconds for Feishu SDK/API calls.
FEISHU_API_TIMEOUT="10"

# FEISHU_TASK_POLL_INTERVAL: Seconds between Gateway task status polls.
FEISHU_TASK_POLL_INTERVAL="2"

# FEISHU_TERMINAL_REVIEW_GRACE_CHECKS: Extra polls before sending terminal
# status when a task may still expose a pending review.
FEISHU_TERMINAL_REVIEW_GRACE_CHECKS="3"

# FEISHU_MEDIA_ROOT: Optional root directory for files that Feishu adapter may
# read/send. Empty uses adapter defaults.
FEISHU_MEDIA_ROOT=

# FEISHU_MEDIA_MAX_BYTES: Maximum file size in bytes that Feishu adapter will
# read/send from generated artifacts.
FEISHU_MEDIA_MAX_BYTES="31457280"

# FEISHU_ACK_MODE: How the adapter acknowledges work. Supported: reaction,
# message, off.
FEISHU_ACK_MODE="reaction"

# FEISHU_REACTIONS: Whether Feishu reaction acknowledgements are enabled.
FEISHU_REACTIONS="true"

# FEISHU_PROCESSING_REACTION: Reaction name while a task is processing.
FEISHU_PROCESSING_REACTION="Typing"

# FEISHU_APPROVAL_REACTION: Reaction name when a task requires approval.
FEISHU_APPROVAL_REACTION="CheckMark"

# FEISHU_FAILURE_REACTION: Reaction name when a task fails.
FEISHU_FAILURE_REACTION="CrossMark"
