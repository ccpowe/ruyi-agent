# Copy this file to `.env`.
# Fill the first section, then fill only the channel credentials you plan to use.
# Never commit `.env`; it may contain API keys, bot tokens, and gateway secrets.


## 1. Model credential

# The default config/agents.toml uses provider = "openrouter".
# For the starter config, this is the only model credential you need.
OPENROUTER_API_KEY=

# Optional model keys. Set only when config/agents.toml uses these providers.
# KIMI_API_KEY=
# DEEPSEEK_API_KEY=
# ZAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=


## 2. Channel credentials

# Telegram mode only. Create one with BotFather.
TELEGRAM_BOT_TOKEN=

# Feishu/Lark mode only.
FEISHU_APP_ID=
FEISHU_APP_SECRET=


## 3. Local defaults

# Default entrypoint when running `python main.py` without an argument.
# Supported values: gateway, telegram, feishu, tui, interactive.
APP_MODE="gateway"

# Stable node identifier used by delegation loop detection.
# Keep the default for single-node local use; change it for multi-node A2A setups.
AGENT_NODE_ID="local-dev"

# Gateway bind address. The default dev token is allowed only on loopback hosts.
GATEWAY_HOST="127.0.0.1"
GATEWAY_PORT="8000"
GATEWAY_BASE_URL="http://127.0.0.1:8000"
GATEWAY_BEARER_TOKEN="dev-token"

# Tool execution backend. Use "local" for development, or "daytona" for sandboxing.
BACKEND_KIND="local"

# Runtime state. These paths are created automatically when needed.
CHECKPOINT_DB="data/checkpoints.sqlite"
GATEWAY_ROUTE_DB="data/gateway_routes.sqlite"
TASK_DB="data/tasks.sqlite"
REVIEW_AUDIT_DB="data/review_audit.sqlite"
CHANNEL_SESSION_DB="data/channel_sessions.sqlite3"


## 4. Backend tuning

# Root directory exposed to the local backend. Empty means the current directory.
LOCAL_BACKEND_ROOT=

# Local backend command limits.
LOCAL_BACKEND_TIMEOUT="120"
LOCAL_BACKEND_MAX_OUTPUT_BYTES="100000"
LOCAL_BACKEND_INHERIT_ENV="true"

# Optional skills directory exposed to agents in the local backend virtual filesystem.
# If set to an absolute path, it must be inside LOCAL_BACKEND_ROOT.
LOCAL_BACKEND_SKILLS_ROOT=

# Daytona sandbox settings. Required only when BACKEND_KIND="daytona".
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
DAYTONA_SANDBOX_NAME=


## 5. Runtime limits and integrations

AGENT_MAX_DELEGATION_DEPTH="3"
AGENT_MAX_TASKS_PER_ROOT="20"

# Optional webhook URL for child task terminal notifications.
A2A_WEBHOOK_URL=
A2A_WEBHOOK_TOKEN=

# Optional bearer token used by the commented remote_ref example in config/agents.toml.
REMOTE_RESEARCH_TOKEN=

# Optional OpenAI-compatible Kimi endpoint used by development probes.
KIMI_OPENAI_BASE_URL=


## 6. LangSmith tracing

LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=


## 7. Telegram defaults

TELEGRAM_DEFAULT_AGENT="main"
TELEGRAM_SESSION_DB="data/channel_sessions.sqlite3"
TELEGRAM_UPDATE_DB="data/telegram_updates.sqlite3"
TELEGRAM_POLL_TIMEOUT="30"
TELEGRAM_API_TIMEOUT="40"
TELEGRAM_TASK_POLL_INTERVAL="2"
TELEGRAM_TERMINAL_REVIEW_GRACE_CHECKS="3"
TELEGRAM_MESSAGE_PARSE_MODE="MarkdownV2"
TELEGRAM_MEDIA_MAX_BYTES="52428800"
TELEGRAM_FALLBACK_IPS=

# Kroki is used to render Mermaid diagrams for Telegram.
KROKI_BASE_URL="https://kroki.io"


## 8. Feishu / Lark defaults

FEISHU_DOMAIN="feishu"
FEISHU_CONNECTION_MODE="websocket"
FEISHU_DEFAULT_AGENT="main"
FEISHU_SESSION_DB="data/channel_sessions.sqlite3"
FEISHU_EVENT_DB="data/feishu_events.sqlite3"

# DM-only by default. For group chats, set FEISHU_GROUP_POLICY="open" and keep
# FEISHU_REQUIRE_MENTION="true" with a bot identity or allowlist below.
FEISHU_GROUP_POLICY="disabled"
FEISHU_REQUIRE_MENTION="true"
FEISHU_ALLOWED_USERS=
FEISHU_ALLOWED_GROUPS=
FEISHU_BOT_NAME=
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_USER_ID=
FEISHU_BOT_UNION_ID=

FEISHU_API_TIMEOUT="10"
FEISHU_TASK_POLL_INTERVAL="2"
FEISHU_TERMINAL_REVIEW_GRACE_CHECKS="3"
FEISHU_MEDIA_ROOT=
FEISHU_MEDIA_MAX_BYTES="31457280"
FEISHU_ACK_MODE="reaction"
FEISHU_REACTIONS="true"
FEISHU_PROCESSING_REACTION="Typing"
FEISHU_APPROVAL_REACTION="CheckMark"
FEISHU_FAILURE_REACTION="CrossMark"
